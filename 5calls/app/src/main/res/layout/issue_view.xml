<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/issueViewStyle">

    <TextView
        android:id="@+id/state_indicator"
        style="@style/stateIndicatorStyle"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/issue_name"
        style="@style/issueViewTextStyle"
        android:layout_width="0dp"
        app:layout_constraintTop_toBottomOf="@id/state_indicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/bookmark_icon"
        android:layout_width="@dimen/accessibility_min_size"
        android:layout_height="@dimen/accessibility_min_size"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:src="@drawable/bookmark_outline_24"
        android:contentDescription="@string/bookmark_issue"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="@id/issue_call_count"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/issue_call_count"
        style="@style/issueCallCountStyle"
        app:layout_constraintTop_toBottomOf="@id/issue_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/bookmark_icon"/>

    <TextView
        android:id="@+id/previous_call_stats"
        style="@style/issuePreviousCallStatsStyle"
        app:drawableStartCompat="@drawable/checked_small"
        app:layout_constraintTop_toBottomOf="@id/issue_call_count"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/bookmark_icon"/>
</androidx.constraintlayout.widget.ConstraintLayout>
